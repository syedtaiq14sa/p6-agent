{
  "name": "p6-agent",
  "version": "1.2.1",
  "description": "P6 Intelligence Desktop Agent",
  "main": "src/main.js",
  "author": "P6 Intelligence",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.p6intelligence.agent",
    "productName": "P6 Intelligence Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "syedtaiq14sa",
      "repo": "p6-agent"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  }
}
